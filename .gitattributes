# Force Unix line endings for all shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Force Unix line endings for hook scripts
.claude/hooks/* text eol=lf

# Standard text files
*.md text eol=auto
*.json text eol=auto
*.js text eol=auto
*.jsx text eol=auto
*.ts text eol=auto
*.tsx text eol=auto
*.css text eol=auto
*.html text eol=auto
